#!/usr/bin/env python3
import os
import re
import shutil
import tarfile
import tomllib
import subprocess
from pathlib import Path
import multiprocessing
import argparse

PLX = Path("/")
PCK_PATH = Path(os.environ.get("PLX_PCK_PATH", "/usr/share/pullinux/packages"))
BUILD_ROOT = PLX / "tmp/build"
SOURCE_CACHE = PLX / "sources"
PCK_OUTPUT_DIR = PCK_PATH / "bin" # Where the built .txz files live

# Local build means that it won't build in a chroot environment.
local_build = True

def get_latest_version(pkg_name):
    # Finds the highest version number available in the package recipes.
    first_char = pkg_name[0].lower()
    pkg_root = PCK_PATH / first_char
    if not pkg_root.exists():
        return None
    
    pattern = f"{pkg_name}-*"
    matches = list(pkg_root.glob(pattern))
    if not matches:
        return None
    
    # Natural sort for versions (e.g., 2.11 > 2.2)
    versions = [m.name.replace(f"{pkg_name}-", "") for m in matches]
    versions.sort(key=lambda s: [int(u) if u.isdigit() else u for u in re.split(r'(\d+)', s)])
    return versions[-1]

def get_first_child_dir(parent_path):
    # This is for finding a directory in a given path, used for extraction of source tar
    # to find the default path that was extracted.
    path = Path(parent_path)
    
    try:
        first_dir = next(p for p in path.iterdir() if p.is_dir())
        return first_dir.name
    except StopIteration:
        return None


def get_source_file(url):
    source_filename = url.split('/')[-1]
    source_file = SOURCE_CACHE / source_filename

    # If source code is not in the download cache, download it with wget...
    if not source_file.exists():
        if not Path("/usr/bin/wget").exists():
            print(f"BUILD:> ERROR: File not cached and wget not installed: {url}")
            exit(1)

        print(f"BUILD:> Downloading {url}...")
        subprocess.run(["wget", url, "-P", str(SOURCE_CACHE)], check=True)

    if not source_file.exists():
        print(f"BUILD:> ERROR: FAILED TO DOWNLOAD REQUIRED FILE: {url}")
        exit(1)

def build_package(name, version=None):
    if not version:
        version = get_latest_version(name)
        if not version: 
            print(f"BUILD:> ERROR: Package {name} not found."); 
            exit(1)

    pkg_dir = PCK_PATH / name[0].lower() / f"{name}-{version}"
    with open(pkg_dir / "pck.toml", "rb") as f:
        recipe = tomllib.load(f)

    # Clean and Setup Build & Pkg directories
    pkg_stage_dir = PLX / "tmp/pkg"  # This is $PCKDIR

    for d in [BUILD_ROOT, pkg_stage_dir]:
        if d.exists(): shutil.rmtree(d)
        d.mkdir(parents=True)
    
    install_dir = pkg_dir / ".install"

    if install_dir.exists():
        print("BUILD:> Copying installer...")
        shutil.copytree(install_dir, PLX / "tmp/pkg/.install")

    print(f"BUILD:> Copying package data to {BUILD_ROOT}")
    for item in pkg_dir.iterdir():
        if item.is_dir(): shutil.copytree(item, BUILD_ROOT / item.name)
        else: shutil.copy2(item, BUILD_ROOT / item.name)

    # This will be the first main directory from an extracted source tar, if one exists...
    top_dir = ""

    source_extract_dir = BUILD_ROOT / "source"
    source_extract_dir.mkdir()
    
    if recipe['source'] != "none":
        source_filename = recipe['source'].split('/')[-1]
        source_tar = SOURCE_CACHE / source_filename
        
        get_source_file(recipe['source'])
            
        print(f"BUILD:> Extracting {source_filename}...")
        subprocess.run(["tar", "-xf", str(source_tar), "-C", str(source_extract_dir)], check=True)

        top_dir = get_first_child_dir(source_extract_dir)
    
    working_dir = f"/tmp/build/source/{top_dir}"

    # Download any extra files
    for extra_url in recipe.get('extras', []):
        extra_filename = extra_url.split('/')[-1]
        extra_path = SOURCE_CACHE / extra_filename

        get_source_file(extra_url)

        shutil.copy2(extra_path, source_extract_dir)

    
    print(f"BUILD:> Starting build for {name}-{version}...")
    print(f"BUILD:> Running in {working_dir}")

    cores = multiprocessing.cpu_count()
    
    build_script = (
        f"export MAKEFLAGS=-j$(nproc); export PCKDIR=/tmp/pkg; "
        f"cd {working_dir} && "
        f"/bin/bash -e /tmp/build/build.sh"
    )
    
    build_cmd = [
            "chroot", str(PLX), "/usr/bin/env", "-i",
            "HOME=/root", "TERM=xterm-256color", "PCKDIR=/tmp/pkg",
            "PATH=/usr/bin:/usr/sbin",
            "/bin/bash", "--login", "-c", build_script
        ]

    if local_build:
        build_cmd = [
            "/bin/bash", "--login", "-c", build_script
        ]
    else:
        print(f"BUILD:> Building in chroot {PLX}")

    try:
        subprocess.run(build_cmd, check=True)
    except subprocess.CalledProcessError:
        print(f"\nBUILD:> ERROR: Build FAILED. Check {PLX}/tmp/build for details."); 
        exit(1)

    # Packaging (.txz creation)
    PCK_OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    package_filename = f"{name}-{version}-plx-3.0.txz"
    package_full_path = PCK_OUTPUT_DIR / package_filename

    print(f"BUILD:> Packaging {name} into {package_filename}...")
    
    # We run tar from the host, but we CD into the pkg_stage_dir first
    # so the tar file doesn't contain the full /mnt/plx/tmp/pkg path.
    # '.' ensures the tar starts at the root of the package.
    tar_cmd = [
        "tar", "-cJpf", str(package_full_path), "-C", str(pkg_stage_dir), "."
    ]
    
    try:
        subprocess.run(tar_cmd, check=True)
        print(f"\nBUILD:> SUCCESS: Package created at {package_full_path}")
    except subprocess.CalledProcessError:
        print(f"BUILD:> ERROR: Error creating the .txz archive."); 
        exit(1)

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Build a package for Pullinux")
    parser.add_argument("name", help="Name of the package")
    parser.add_argument("-v", "--version", help="Specific version")
    parser.add_argument("-d", "--dest", help="Destination of where to build in a chroot environment")

    args = parser.parse_args()

    if args.dest:
        local_build = False
        PLX = Path(args.dest)
        BUILD_ROOT = PLX / "tmp/build"
        SOURCE_CACHE = PLX / "sources"
        PCK_OUTPUT_DIR = PCK_PATH / "bin"

        if not (PLX / "dev/tty").exists():
            print(f"First you must mount virtual environment in {PLX}")
            exit(1)

    build_package(args.name, args.version)
